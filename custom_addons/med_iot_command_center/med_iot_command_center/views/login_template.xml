<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="med_login_page" name="MedIoT Custom Login Page">
        <t t-call="website.layout">
            <div class="med_login_wrap">
                <!-- LEFT SIDE -->
                <div class="med_login_left">
                    <img src="/med_iot_command_center/static/description/hero_new.jpg?v=2" alt="Hospital"/>
                    <div class="med_login_overlay"/>

                    <div class="med_top_badge">
                        <div class="med_badge_icon">
                            <img src="/med_iot_command_center/static/description/INJ.png" alt="logo"/>
                        </div>
                        <div>
                            <div class="med_badge_name">MedIoT</div>
                            <div class="med_badge_sub">Command Center</div>
                        </div>
                    </div>

                    <div class="med_hero">
                        <h1>Real-Time Patient<br/>Monitoring Platform</h1>
                        <p>AI-powered vital signs monitoring with instant alerts and centralized patient management.</p>
                    </div>
                </div>

                <!-- RIGHT SIDE -->
                <div class="med_login_right">
                    <div class="med_panel_logo">
                        <div class="med_panel_logo_icon">
                            <img src="/med_iot_command_center/static/description/INJ.png" alt="logo"/>
                        </div>
                        <div class="med_panel_logo_name">MedIoT</div>
                    </div>

                    <div class="med_login_title">Welcome back</div>
                    <div class="med_login_subtitle">Sign in to your MedIoT account</div>

                    <t t-if="error">
                        <div class="med_err">
                            <t t-esc="error"/>
                        </div>
                    </t>

                    <form action="/web/login" method="post">
                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                        <input type="hidden" name="redirect" t-att-value="redirect"/>

                        <div class="med_field">
                            <label>Email</label>
                            <input type="text"
                                   name="login"
                                   placeholder="your@email.com"
                                   t-att-value="login"
                                   required="required"
                                   autofocus="autofocus"/>
                        </div>

                        <div class="med_field">
                            <label>Password</label>
                            <input type="password"
                                   name="password"
                                   placeholder="••••••••"
                                   required="required"/>
                        </div>

                        <button type="submit" class="med_btn">Sign In</button>
                    </form>

                    <div class="med_links">
                        <a href="/mediot/reset">Forgot password?</a>
                        &#160;·&#160;
                        <a href="/mediot/signup">Create account</a>
                        &#160;·&#160;
                        <a href="/mediot">Back to home</a>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
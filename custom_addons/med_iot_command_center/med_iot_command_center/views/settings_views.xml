<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_med_settings_form" model="ir.ui.view">
        <field name="name">med.settings.form</field>
        <field name="model">med.settings</field>
        <field name="arch" type="xml">
            <form string="Settings">
                <sheet style="padding:0 !important; background:#f8f9fb;">

                    <!-- HEADER BANNER -->
                    <div style="background:linear-gradient(135deg,#5c6bc0 0%,#7986cb 50%,#9575cd 100%);padding:20px 36px;display:flex;align-items:center;justify-content:space-between;margin:-16px -32px 28px -32px;">
                        <div style="display:flex;align-items:center;gap:16px;">

                    <div style="padding:0 32px 32px;">

                        <!-- ══════════ DEVICE SECTION ══════════ -->
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
                            <div style="width:30px;height:30px;border-radius:8px;background:#eef0fb;display:flex;align-items:center;justify-content:center;overflow:hidden;">
                                <img src="/med_iot_command_center/static/description/l.png" style="width:22px;height:22px;object-fit:contain;"/>
                            </div>
                            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#5c6bc0;letter-spacing:.08em;">IoT Device</div>
                            <div style="flex:1;height:1px;background:#dde0f5;"/>
                        </div>

                        <div style="display:grid;grid-template-columns:180px 1fr;gap:14px;margin-bottom:14px;">
                            <div style="background:#fff;border:1px solid #e8eaf6;border-radius:14px;padding:18px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;box-shadow:0 1px 4px rgba(92,107,192,.06);">
                                <div style="width:60px;height:60px;border-radius:50%;border:3px solid #dde0f5;overflow:hidden;display:flex;align-items:center;justify-content:center;">
                                    <img src="/med_iot_command_center/static/description/s.png" style="width:44px;height:44px;object-fit:contain;"/>
                                </div>
                                <div style="text-align:center;">
                                    <div style="font-size:.88rem;font-weight:700;color:#5c6bc0;">ESP32 Device</div>
                                    <div style="font-size:.62rem;color:#94a3b8;margin-top:2px;">IoT Wearable · DOIT DevKit</div>
                                </div>
                            </div>
                            <div style="background:#fff;border:1px solid #e8eaf6;border-radius:14px;padding:18px 22px;box-shadow:0 1px 4px rgba(92,107,192,.06);">
                                <div style="font-size:.58rem;font-weight:700;text-transform:uppercase;color:#5c6bc0;margin-bottom:14px;padding-bottom:8px;border-bottom:1.5px solid #eef0fb;letter-spacing:.07em;">Device Configuration</div>
                                <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
                                    <div>
                                        <div style="font-size:.58rem;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;font-weight:600;">MQTT Topic</div>
                                        <div style="font-size:.85rem;background:#f5f6fd;border:1.5px solid #dde0f5;border-radius:7px;padding:8px 10px;font-family:monospace;color:#3730a3;">esp32/vitals</div>
                                    </div>
                                    <div>
                                        <div style="font-size:.58rem;text-transform:uppercase;color:#94a3b8;margin-bottom:4px;font-weight:600;">Connection</div>
                                        <div style="font-size:.85rem;background:#f0fdf4;border:1.5px solid #a7f3d0;border-radius:7px;padding:8px 10px;color:#166534;font-weight:600;">● Online</div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div style="background:#fff;border:1px solid #e8eaf6;border-radius:14px;padding:18px 22px;margin-bottom:28px;box-shadow:0 1px 4px rgba(92,107,192,.06);">
                            <div style="font-size:.58rem;font-weight:700;text-transform:uppercase;color:#5c6bc0;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid #eef0fb;letter-spacing:.07em;">Onboard Sensors</div>
                            <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;">
                                <div style="border:1px solid #bfdbfe;border-radius:10px;padding:14px 10px;text-align:center;background:linear-gradient(135deg,#f0f7ff,#dbeafe);">
                                    <div style="width:46px;height:46px;border-radius:12px;background:#dbeafe;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;overflow:hidden;"><img src="/med_iot_command_center/static/description/sensor_ecg.png" style="width:32px;height:32px;object-fit:contain;" onerror="this.style.display='none'"/></div>
                                    <div style="font-size:.8rem;font-weight:700;color:#1e40af;">AD8232</div>
                                    <div style="font-size:.6rem;color:#3b82f6;margin-top:2px;">ECG Monitor</div>
                                    <div style="margin-top:8px;display:inline-block;background:#1e40af;color:#fff;font-size:.52rem;font-weight:700;padding:3px 10px;border-radius:20px;">ACTIVE</div>
                                </div>
                                <div style="border:1px solid #a7f3d0;border-radius:10px;padding:14px 10px;text-align:center;background:linear-gradient(135deg,#f0fff8,#dcfce7);">
                                    <div style="width:46px;height:46px;border-radius:12px;background:#dcfce7;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;overflow:hidden;"><img src="/med_iot_command_center/static/description/sensor_spo2.png" style="width:32px;height:32px;object-fit:contain;" onerror="this.style.display='none'"/></div>
                                    <div style="font-size:.8rem;font-weight:700;color:#166534;">MAX30102</div>
                                    <div style="font-size:.6rem;color:#16a34a;margin-top:2px;">SpO2 + Heart Rate</div>
                                    <div style="margin-top:8px;display:inline-block;background:#166534;color:#fff;font-size:.52rem;font-weight:700;padding:3px 10px;border-radius:20px;">ACTIVE</div>
                                </div>
                                <div style="border:1px solid #fed7aa;border-radius:10px;padding:14px 10px;text-align:center;background:linear-gradient(135deg,#fffaf0,#ffedd5);">
                                    <div style="width:46px;height:46px;border-radius:12px;background:#ffedd5;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;overflow:hidden;"><img src="/med_iot_command_center/static/description/sensor_temp.png" style="width:32px;height:32px;object-fit:contain;" onerror="this.style.display='none'"/></div>
                                    <div style="font-size:.8rem;font-weight:700;color:#9a3412;">DS18B20</div>
                                    <div style="font-size:.6rem;color:#ea580c;margin-top:2px;">Body Temperature</div>
                                    <div style="margin-top:8px;display:inline-block;background:#9a3412;color:#fff;font-size:.52rem;font-weight:700;padding:3px 10px;border-radius:20px;">ACTIVE</div>
                                </div>
                                <div style="border:1px solid #c5cae9;border-radius:10px;padding:14px 10px;text-align:center;background:linear-gradient(135deg,#f5f6fd,#eef0fb);">
                                    <div style="width:46px;height:46px;border-radius:12px;background:#dde0f5;display:flex;align-items:center;justify-content:center;margin:0 auto 8px;overflow:hidden;"><img src="/med_iot_command_center/static/description/sensor_lcd.png" style="width:32px;height:32px;object-fit:contain;" onerror="this.style.display='none'"/></div>

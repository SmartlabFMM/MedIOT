                                    <div style="margin-top:8px;display:inline-block;background:#5c6bc0;color:#fff;font-size:.52rem;font-weight:700;padding:3px 10px;border-radius:20px;">ACTIVE</div>
                                </div>
                            </div>
                        </div>

                        <!-- ══════════ ALERT THRESHOLDS ══════════ -->

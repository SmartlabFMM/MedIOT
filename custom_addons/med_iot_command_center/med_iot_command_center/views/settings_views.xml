                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#ef4444;padding:3px 12px;border-radius:6px;">Seuil : <field name="hr_critical_min" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:32px;text-align:center;"/> bpm</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:20%;background:linear-gradient(90deg,#ef4444,#f87171);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>0 bpm</span><span>200 bpm</span></div>
                                </div>
                                <div style="margin-bottom:18px;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🔴 Critical Max — above this triggers immediate alert</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#ef4444;padding:3px 12px;border-radius:6px;">Seuil : <field name="hr_critical_max" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:32px;text-align:center;"/> bpm</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:65%;background:linear-gradient(90deg,#ef4444,#f87171);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>0 bpm</span><span>200 bpm</span></div>
                                </div>
                                <div style="margin-bottom:18px;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🟡 Warning Min — below this triggers warning alert</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#f59e0b;padding:3px 12px;border-radius:6px;">Seuil : <field name="hr_warning_min" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:32px;text-align:center;"/> bpm</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:25%;background:linear-gradient(90deg,#f59e0b,#fbbf24);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>0 bpm</span><span>200 bpm</span></div>
                                </div>
                                <div>
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🟡 Warning Max — above this triggers warning alert</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#f59e0b;padding:3px 12px;border-radius:6px;">Seuil : <field name="hr_warning_max" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:32px;text-align:center;"/> bpm</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:55%;background:linear-gradient(90deg,#f59e0b,#fbbf24);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>0 bpm</span><span>200 bpm</span></div>
                                </div>
                            </div>

                            <div style="border-top:1px solid #f1f5f9;margin-bottom:28px;"/>

                            <!-- SPO2 -->
                            <div style="margin-bottom:28px;">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">
                                    <span style="font-size:1rem;">💧</span>
                                    <span style="font-size:.82rem;font-weight:600;color:#374151;">Blood Oxygen (SpO2)</span>
                                </div>
                                <div style="margin-bottom:18px;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🔴 Critical Min — below this = hypoxia alert</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#ef4444;padding:3px 12px;border-radius:6px;">Seuil : <field name="spo2_critical_min" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:32px;text-align:center;"/> %</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:85%;background:linear-gradient(90deg,#ef4444,#f87171);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>70%</span><span>100%</span></div>
                                </div>
                                <div>
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🟡 Warning Min — below this = low SpO2 warning</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#f59e0b;padding:3px 12px;border-radius:6px;">Seuil : <field name="spo2_warning_min" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:32px;text-align:center;"/> %</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:90%;background:linear-gradient(90deg,#f59e0b,#fbbf24);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>70%</span><span>100%</span></div>
                                </div>
                            </div>

                            <div style="border-top:1px solid #f1f5f9;margin-bottom:28px;"/>

                            <!-- TEMPERATURE -->
                            <div style="margin-bottom:28px;">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">
                                    <span style="font-size:1rem;">🌡️</span>
                                    <span style="font-size:.82rem;font-weight:600;color:#374151;">Body Temperature</span>
                                </div>
                                <div style="margin-bottom:18px;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🔴 Critical Min — below this = hypothermia alert</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#ef4444;padding:3px 12px;border-radius:6px;">Seuil : <field name="temp_critical_min" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:36px;text-align:center;"/> °C</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:33%;background:linear-gradient(90deg,#ef4444,#f87171);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>30°C</span><span>45°C</span></div>
                                </div>
                                <div style="margin-bottom:18px;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🔴 Critical Max — above this = high fever alert</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#ef4444;padding:3px 12px;border-radius:6px;">Seuil : <field name="temp_critical_max" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:36px;text-align:center;"/> °C</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:60%;background:linear-gradient(90deg,#ef4444,#f87171);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>30°C</span><span>45°C</span></div>
                                </div>
                                <div style="margin-bottom:18px;">
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🟡 Warning Min — below this = low temp warning</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#f59e0b;padding:3px 12px;border-radius:6px;">Seuil : <field name="temp_warning_min" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:36px;text-align:center;"/> °C</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:40%;background:linear-gradient(90deg,#f59e0b,#fbbf24);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>30°C</span><span>45°C</span></div>
                                </div>
                                <div>
                                    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                        <span style="font-size:.75rem;color:#6b7280;">🟡 Warning Max — above this = fever warning</span>
                                        <span style="font-size:.75rem;font-weight:700;color:#fff;background:#f59e0b;padding:3px 12px;border-radius:6px;">Seuil : <field name="temp_warning_max" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:36px;text-align:center;"/> °C</span>
                                    </div>
                                    <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                        <div style="position:absolute;left:0;top:0;height:100%;width:52%;background:linear-gradient(90deg,#f59e0b,#fbbf24);border-radius:999px;"/>
                                    </div>
                                    <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>30°C</span><span>45°C</span></div>
                                </div>
                            </div>

                            <!-- Footer note -->
                            <div style="display:flex;align-items:center;gap:8px;font-size:.72rem;color:#94a3b8;background:#f8fafc;border-radius:8px;padding:10px 14px;margin-top:8px;">
                                <span>ℹ️</span>
                                <span>Ces seuils sont appliqués immédiatement après enregistrement.</span>
                            </div>
                        </div>

                        <!-- ══════════ SYSTEM SECTION ══════════ -->
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;">
                            <div style="width:30px;height:30px;border-radius:8px;background:#eef0fb;display:flex;align-items:center;justify-content:center;font-size:.9rem;">🔄</div>
                            <div style="font-size:.7rem;font-weight:700;text-transform:uppercase;color:#5c6bc0;letter-spacing:.08em;">System</div>
                            <div style="flex:1;height:1px;background:#dde0f5;"/>
                        </div>

                        <div style="background:#fff;border:1px solid #e8eaf6;border-radius:16px;padding:28px 32px;box-shadow:0 1px 4px rgba(92,107,192,.06);">
                            <div style="font-size:.82rem;font-weight:600;color:#374151;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
                                <span>⏱️</span> Dashboard Auto-Refresh Interval
                            </div>
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;">
                                <span style="font-size:.75rem;color:#6b7280;">Recommended: 15 seconds</span>
                                <span style="font-size:.75rem;font-weight:700;color:#fff;background:#5c6bc0;padding:3px 12px;border-radius:6px;">Seuil : <field name="check_interval_seconds" nolabel="1" style="display:inline;background:transparent;border:none;padding:0;font-size:inherit;font-weight:inherit;color:inherit;width:32px;text-align:center;"/> s</span>
                            </div>
                            <div style="position:relative;height:10px;background:#f1f5f9;border-radius:999px;overflow:hidden;">
                                <div style="position:absolute;left:0;top:0;height:100%;width:22%;background:linear-gradient(90deg,#5c6bc0,#9575cd);border-radius:999px;"/>
                            </div>
                            <div style="display:flex;justify-content:space-between;font-size:.6rem;color:#cbd5e1;margin-top:3px;"><span>5s</span><span>120s</span></div>
                        </div>

                    </div>
                </sheet>
            </form>
        </field>
    </record>


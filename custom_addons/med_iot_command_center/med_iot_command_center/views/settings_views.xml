                        </div>

                        <div style="background:#fff;border:1px solid #e8eaf6;border-radius:16px;padding:28px 32px;margin-bottom:28px;box-shadow:0 1px 4px rgba(92,107,192,.06);">
                            <div style="font-size:1rem;font-weight:700;color:#1e293b;margin-bottom:4px;">Les limites des alertes vitales</div>
                            <div style="font-size:.78rem;color:#94a3b8;margin-bottom:28px;">Ajustez les seuils d'alerte selon vos besoins</div>

                            <!-- HEART RATE -->
                            <div style="margin-bottom:28px;">
                                <div style="display:flex;align-items:center;gap:8px;margin-bottom:16px;">

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="med_admin_dashboard_singleton" model="med.admin.dashboard">
        <field name="name">Admin Dashboard</field>
    </record>

    <record id="view_med_admin_dashboard_form" model="ir.ui.view">
        <field name="name">med.admin.dashboard.form</field>
        <field name="model">med.admin.dashboard</field>
        <field name="arch" type="xml">
            <form string="Admin Dashboard" create="0" edit="0" delete="0">
                <sheet class="mediot_admin_dashboard_page" style="max-width:100%;padding:0;margin:0;background:#eef2ff;border:0;">

                    <div style="background:linear-gradient(135deg,#667eea 0%,#9f7aea 100%);padding:20px 24px;color:white;border-radius:0 0 18px 18px;margin:-16px -16px 14px -16px;">
                        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:20px;">
                            <div>
                                <div style="font-size:13px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;opacity:.85;">MedIoT Administration</div>
                                <h1 style="font-size:26px;font-weight:900;margin:4px 0 4px;color:white;">Admin Command Center</h1>
                                <p style="font-size:14px;margin:0;opacity:.9;">Manage users, patients, alerts, devices, and system operations.</p>
                            </div>
                            <div style="display:flex;gap:12px;align-items:center;">
                                <button name="action_open_doctors" type="object" string="Manage Users" class="btn btn-light" icon="fa-users"/>
                                <button name="action_open_devices" type="object" string="Devices" class="btn btn-light" icon="fa-microchip"/>
                            </div>
                        </div>
                    </div>

                    <div style="display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px;margin:0 18px 18px;">
                        <button name="action_open_doctors" type="object" style="text-align:left;background:white;border:1px solid #e2e8f0;border-radius:22px;padding:22px;box-shadow:0 14px 35px rgba(15,23,42,.08);">
                            <div style="display:flex;align-items:center;gap:16px;">
                                <div style="width:58px;height:58px;border-radius:18px;background:#eef2ff;color:#4f46e5;display:flex;align-items:center;justify-content:center;font-size:26px;">
                                    <i class="fa fa-users"/>
                                </div>
                                <div>
                                    <div style="font-size:13px;font-weight:800;color:#64748b;text-transform:uppercase;">Users / Staff</div>
                                    <div style="font-size:34px;font-weight:900;color:#1e293b;line-height:1;">
                                        <field name="doctor_count" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </button>

                        <button name="action_open_patients" type="object" style="text-align:left;background:white;border:1px solid #e2e8f0;border-radius:22px;padding:22px;box-shadow:0 14px 35px rgba(15,23,42,.08);">
                            <div style="display:flex;align-items:center;gap:16px;">
                                <div style="width:58px;height:58px;border-radius:18px;background:#ecfeff;color:#0891b2;display:flex;align-items:center;justify-content:center;font-size:26px;">
                                    <i class="fa fa-users"/>
                                </div>
                                <div>
                                    <div style="font-size:13px;font-weight:800;color:#64748b;text-transform:uppercase;">Total Patients</div>
                                    <div style="font-size:34px;font-weight:900;color:#1e293b;line-height:1;">
                                        <field name="patient_count" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </button>

                        <button name="action_open_alerts" type="object" style="text-align:left;background:white;border:1px solid #fee2e2;border-radius:22px;padding:22px;box-shadow:0 14px 35px rgba(239,68,68,.10);">
                            <div style="display:flex;align-items:center;gap:16px;">
                                <div style="width:58px;height:58px;border-radius:18px;background:#fee2e2;color:#ef4444;display:flex;align-items:center;justify-content:center;font-size:26px;">
                                    <i class="fa fa-exclamation-triangle"/>
                                </div>
                                <div>
                                    <div style="font-size:13px;font-weight:800;color:#ef4444;text-transform:uppercase;">Pending Alerts</div>
                                    <div style="font-size:34px;font-weight:900;color:#ef4444;line-height:1;">
                                        <field name="pending_alert_count" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </button>

                        <button name="action_open_devices" type="object" style="text-align:left;background:white;border:1px solid #e2e8f0;border-radius:22px;padding:22px;box-shadow:0 14px 35px rgba(15,23,42,.08);">
                            <div style="display:flex;align-items:center;gap:16px;">
                                <div style="width:58px;height:58px;border-radius:18px;background:#f0fdf4;color:#16a34a;display:flex;align-items:center;justify-content:center;font-size:26px;">
                                    <i class="fa fa-microchip"/>
                                </div>
                                <div>
                                    <div style="font-size:13px;font-weight:800;color:#64748b;text-transform:uppercase;">Online Devices</div>
                                    <div style="font-size:34px;font-weight:900;color:#1e293b;line-height:1;">
                                        <field name="online_device_count" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </button>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin:0 18px 24px;">
                        <div style="background:white;border:1px solid #e2e8f0;border-radius:22px;padding:22px;box-shadow:0 14px 35px rgba(15,23,42,.06);">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                                <div>
                                    <h2 style="font-size:20px;font-weight:900;margin:0;color:#0f172a;">Critical Patients</h2>
                                    <p style="font-size:13px;color:#94a3b8;margin:4px 0 0;">Patients needing immediate attention</p>
                                </div>
                                <span style="background:#fee2e2;color:#dc2626;border-radius:999px;padding:6px 12px;font-weight:800;font-size:12px;">
                                    <field name="critical_patient_count" nolabel="1"/> Critical
                                </span>
                            </div>
                            <field name="critical_patient_ids" nolabel="1" readonly="1">
                                <list create="0" edit="0" delete="0">
                                    <field name="ref" string="ID"/>
                                    <field name="name"/>
                                    <field name="room"/>
                                    <field name="latest_spo2" string="SpO2"/>
                                    <field name="latest_ecg_bpm" string="HR"/>
                                    <field name="latest_temp" string="Temp"/>
                                    <field name="status"/>
                                </list>
                            </field>
                        </div>

                        <div style="background:white;border:1px solid #e2e8f0;border-radius:22px;padding:22px;box-shadow:0 14px 35px rgba(15,23,42,.06);">
                            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                                <div>
                                    <h2 style="font-size:20px;font-weight:900;margin:0;color:#0f172a;">User Management</h2>
                                    <p style="font-size:13px;color:#94a3b8;margin:4px 0 0;">Admins, doctors, and clinical staff roles</p>
                                </div>
                                <button name="action_open_doctors" type="object" string="Manage Users" class="btn btn-primary" icon="fa-users"/>
                            </div>
                            <field name="doctor_ids" nolabel="1" readonly="1">
                                <list create="0" edit="0" delete="0">
                                    <field name="name"/>
                                    <field name="mediot_role_label" string="Role"/>
                                    <field name="login"/>
                                    <field name="email"/>
                                </list>
                            </field>
                        </div>
                    </div>

                    <div style="margin:0 18px 28px;background:white;border:1px solid #e2e8f0;border-radius:22px;padding:22px;box-shadow:0 14px 35px rgba(15,23,42,.06);">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
                            <div>
                                <h2 style="font-size:20px;font-weight:900;margin:0;color:#0f172a;">Recent Alerts</h2>
                                <p style="font-size:13px;color:#94a3b8;margin:4px 0 0;">Latest clinical and device alerts</p>
                            </div>
                            <button name="action_open_alerts" type="object" string="Open Alerts" class="btn btn-secondary" icon="fa-bell"/>
                        </div>
                        <field name="recent_alert_ids" nolabel="1" readonly="1">
                            <list create="0" edit="0" delete="0">
                                <field name="create_date"/>
                                <field name="patient_id"/>
                                <field name="alert_type"/>
                                <field name="severity"/>
                                <field name="state"/>
                                <field name="message"/>
                            </list>
                        </field>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_med_admin_dashboard" model="ir.actions.act_window">
        <field name="name">Admin Dashboard</field>
        <field name="res_model">med.admin.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_med_admin_dashboard_form"/>
        <field name="res_id" ref="med_admin_dashboard_singleton"/>
        <field name="target">current</field>
    </record>
</odoo>
<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="med_admin_dashboard_singleton" model="med.admin.dashboard">
        <field name="name">Admin Dashboard</field>
    </record>
    <record id="view_med_admin_dashboard_form" model="ir.ui.view">
        <field name="name">med.admin.dashboard.form</field>
        <field name="model">med.admin.dashboard</field>
        <field name="arch" type="xml">
            <form string="Admin Dashboard" create="0" edit="0" delete="0" class="mediot-admin-dashboard-form">
                <sheet class="mediot_admin_page">
                    <div class="med_admin_hero" style="background:linear-gradient(135deg,#4f46e5 0%,#6366f1 40%,#7c3aed 100%);padding:28px 32px;border-radius:20px;margin-bottom:22px;color:#fff;box-shadow:0 20px 50px rgba(79,70,229,.25);">
                        <div>
                            
                            <h1 style="font-size:1.6rem;font-weight:900;margin-bottom:6px;color:#fff;">Admin Command Center</h1>
                            <p style="color:rgba(255,255,255,.85);font-size:.9rem;">Manage clinical teams, patients, alerts, devices, and system operations from one place.</p>
                        </div>
                        <div class="med_admin_hero_actions">
                            <button name="action_open_doctors" type="object" class="med_admin_btn primary">
                                <i class="fa fa-users" title="Users" />
                                Manage Users
                            </button>
                            <button name="action_open_devices" type="object" class="med_admin_btn">
                                <i class="fa fa-microchip" title="Devices" />
                                Devices
                            </button>
                        </div>
                    </div>
                    <div class="med_admin_kpi_grid">
                        <button name="action_open_doctors" type="object" class="med_admin_kpi_card purple" style="border-radius:18px;box-shadow:0 10px 25px rgba(139,92,246,.15);">
                            <div class="med_admin_kpi_icon">
                                <i class="fa fa-user-md" title="Doctors" />
                            </div>
                            <div>
                                <div class="med_admin_kpi_label">Doctors / Staff</div>
                                <div class="med_admin_kpi_value">
                                    <field name="doctor_count" nolabel="1" />
                                </div>
                                <div class="med_admin_kpi_hint">Clinical users</div>
                            </div>
                        </button>
                        <button name="action_open_patients" type="object" class="med_admin_kpi_card cyan" style="border-radius:18px;box-shadow:0 10px 25px rgba(6,182,212,.15);">
                            <div class="med_admin_kpi_icon">
                                <i class="fa fa-address-card-o" title="Patients" />
                            </div>
                            <div>
                                <div class="med_admin_kpi_label">Patients</div>
                                <div class="med_admin_kpi_value">
                                    <field name="patient_count" nolabel="1" />
                                </div>
                                <div class="med_admin_kpi_hint">Active monitored records</div>
                            </div>
                        </button>
                        <button name="action_open_alerts" type="object" class="med_admin_kpi_card red" style="border-radius:18px;box-shadow:0 10px 30px rgba(239,68,68,.15);transform:translateY(0);transition:all .2s ease;">
                            <div class="med_admin_kpi_icon">
                                <i class="fa fa-bell-o" title="Alerts" />
                            </div>
                            <div>
                                <div class="med_admin_kpi_label">Alerts</div>
                                <div class="med_admin_kpi_value">
                                    <field name="pending_alert_count" nolabel="1" />
                                </div>
                                <div class="med_admin_kpi_hint">Recent clinical alerts</div>
                            </div>
                        </button>
                        <button name="action_open_devices" type="object" class="med_admin_kpi_card green" style="border-radius:18px;box-shadow:0 10px 30px rgba(34,197,94,.15);">
                            <div class="med_admin_kpi_icon">
                                <i class="fa fa-wifi" title="Devices" />
                            </div>
                            <div>
                                <div class="med_admin_kpi_label">Online Devices</div>
                                <div class="med_admin_kpi_value">
                                    <field name="online_device_count" nolabel="1" />
                                </div>
                                <div class="med_admin_kpi_hint">Connected IoT units</div>
                            </div>
                        </button>
                    </div>
                    <div class="med_admin_chart_panel" style="background:#fff;border:1px solid #dbeafe;border-radius:20px;padding:20px 22px;margin:22px 0;box-shadow:0 14px 36px rgba(79,70,229,.08);">
                        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;">
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div style="width:42px;height:42px;border-radius:12px;background:#eef2ff;color:#4f46e5;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">
                                    <i class="fa fa-line-chart" title="Trends"/>
                                </div>
                                <div>
                                    <h2 style="font-size:1.05rem;font-weight:900;color:#0f172a;margin:0;">Patient Monitoring Trends</h2>
                                    <p style="color:#64748b;font-size:.8rem;margin:4px 0 0;">Real-time overview of vital signs</p>
                                </div>
                            </div>
                            <div style="display:flex;gap:10px;align-items:center;">
                                <span style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:9px 14px;color:#334155;font-size:.8rem;font-weight:700;">
                                    <i class="fa fa-calendar-o" title="Time"/> Last 24 Hours
                                </span>
                                <span style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:9px 12px;color:#334155;">
                                    <i class="fa fa-refresh" title="Refresh"/>
                                </span>
                            </div>
                        </div>

                        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;">
                            <div style="border:1px solid #e5e7eb;border-radius:16px;padding:16px;background:#ffffff;">
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                                    <strong style="color:#334155;font-size:.86rem;"><i class="fa fa-heart" style="color:#ef4444;"></i> Heart Rate (BPM)</strong>
                                    <span style="color:#ef4444;font-weight:900;font-size:1.1rem;">76</span>
                                </div>
                                <div style="height:115px;border-radius:12px;background:linear-gradient(180deg,#fee2e2,#fff);border:1px dashed #fecaca;display:flex;align-items:center;justify-content:center;color:#ef4444;font-weight:800;">
                                    <svg viewBox="0 0 360 140" style="width:100%;height:100%;">
    <line x1="34" y1="18" x2="340" y2="18" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="52" x2="340" y2="52" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="86" x2="340" y2="86" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="120" x2="340" y2="120" stroke="#cbd5e1" stroke-width="1"/>
    <text x="4" y="22" font-size="10" fill="#64748b">160</text>
    <text x="4" y="56" font-size="10" fill="#64748b">120</text>
    <text x="10" y="90" font-size="10" fill="#64748b">80</text>
    <text x="10" y="124" font-size="10" fill="#64748b">0</text>
    <polygon points="34,62 58,54 82,68 106,50 130,78 154,66 178,70 202,48 226,62 250,56 274,82 298,70 322,88 340,80 340,120 34,120" fill="rgba(239,68,68,.13)"/>
    <polyline points="34,62 58,54 82,68 106,50 130,78 154,66 178,70 202,48 226,62 250,56 274,82 298,70 322,88 340,80" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <g fill="#ef4444">
        <circle cx="34" cy="62" r="3"/><circle cx="58" cy="54" r="3"/><circle cx="82" cy="68" r="3"/><circle cx="106" cy="50" r="3"/><circle cx="130" cy="78" r="3"/><circle cx="154" cy="66" r="3"/><circle cx="178" cy="70" r="3"/><circle cx="202" cy="48" r="3"/><circle cx="226" cy="62" r="3"/><circle cx="250" cy="56" r="3"/><circle cx="274" cy="82" r="3"/><circle cx="298" cy="70" r="3"/><circle cx="322" cy="88" r="3"/><circle cx="340" cy="80" r="3"/>
    </g>
    <text x="34" y="136" font-size="10" fill="#64748b">00:00</text>
    <text x="126" y="136" font-size="10" fill="#64748b">08:00</text>
    <text x="218" y="136" font-size="10" fill="#64748b">16:00</text>
    <text x="310" y="136" font-size="10" fill="#64748b">20:00</text>
</svg>
                                </div>
                            </div>

                            <div style="border:1px solid #e5e7eb;border-radius:16px;padding:16px;background:#ffffff;">
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                                    <strong style="color:#334155;font-size:.86rem;"><i class="fa fa-tint" style="color:#2563eb;"></i> SpO2 (%)</strong>
                                    <span style="color:#2563eb;font-weight:900;font-size:1.1rem;">96%</span>
                                </div>
                                <div style="height:115px;border-radius:12px;background:linear-gradient(180deg,#dbeafe,#fff);border:1px dashed #bfdbfe;display:flex;align-items:center;justify-content:center;color:#2563eb;font-weight:800;">
                                    <svg viewBox="0 0 360 140" style="width:100%;height:100%;">
    <line x1="34" y1="18" x2="340" y2="18" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="52" x2="340" y2="52" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="86" x2="340" y2="86" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="120" x2="340" y2="120" stroke="#cbd5e1" stroke-width="1"/>
    <text x="4" y="22" font-size="10" fill="#64748b">160</text>
    <text x="4" y="56" font-size="10" fill="#64748b">120</text>
    <text x="10" y="90" font-size="10" fill="#64748b">80</text>
    <text x="10" y="124" font-size="10" fill="#64748b">0</text>
    <polygon points="34,62 58,54 82,68 106,50 130,78 154,66 178,70 202,48 226,62 250,56 274,82 298,70 322,88 340,80 340,120 34,120" fill="rgba(37,99,235,.13)"/>
    <polyline points="34,62 58,54 82,68 106,50 130,78 154,66 178,70 202,48 226,62 250,56 274,82 298,70 322,88 340,80" fill="none" stroke="#2563eb" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <g fill="#2563eb">
        <circle cx="34" cy="62" r="3"/><circle cx="58" cy="54" r="3"/><circle cx="82" cy="68" r="3"/><circle cx="106" cy="50" r="3"/><circle cx="130" cy="78" r="3"/><circle cx="154" cy="66" r="3"/><circle cx="178" cy="70" r="3"/><circle cx="202" cy="48" r="3"/><circle cx="226" cy="62" r="3"/><circle cx="250" cy="56" r="3"/><circle cx="274" cy="82" r="3"/><circle cx="298" cy="70" r="3"/><circle cx="322" cy="88" r="3"/><circle cx="340" cy="80" r="3"/>
    </g>
    <text x="34" y="136" font-size="10" fill="#64748b">00:00</text>
    <text x="126" y="136" font-size="10" fill="#64748b">08:00</text>
    <text x="218" y="136" font-size="10" fill="#64748b">16:00</text>
    <text x="310" y="136" font-size="10" fill="#64748b">20:00</text>
</svg>
                                </div>
                            </div>

                            <div style="border:1px solid #e5e7eb;border-radius:16px;padding:16px;background:#ffffff;">
                                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
                                    <strong style="color:#334155;font-size:.86rem;"><i class="fa fa-thermometer-half" style="color:#16a34a;"></i> Temperature (°C)</strong>
                                    <span style="color:#16a34a;font-weight:900;font-size:1.1rem;">37.2°C</span>
                                </div>
                                <div style="height:115px;border-radius:12px;background:linear-gradient(180deg,#dcfce7,#fff);border:1px dashed #bbf7d0;display:flex;align-items:center;justify-content:center;color:#16a34a;font-weight:800;">
                                    <svg viewBox="0 0 360 140" style="width:100%;height:100%;">
    <line x1="34" y1="18" x2="340" y2="18" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="52" x2="340" y2="52" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="86" x2="340" y2="86" stroke="#e5e7eb" stroke-width="1"/>
    <line x1="34" y1="120" x2="340" y2="120" stroke="#cbd5e1" stroke-width="1"/>
    <text x="4" y="22" font-size="10" fill="#64748b">160</text>
    <text x="4" y="56" font-size="10" fill="#64748b">120</text>
    <text x="10" y="90" font-size="10" fill="#64748b">80</text>
    <text x="10" y="124" font-size="10" fill="#64748b">0</text>
    <polygon points="34,62 58,54 82,68 106,50 130,78 154,66 178,70 202,48 226,62 250,56 274,82 298,70 322,88 340,80 340,120 34,120" fill="rgba(22,163,74,.13)"/>
    <polyline points="34,62 58,54 82,68 106,50 130,78 154,66 178,70 202,48 226,62 250,56 274,82 298,70 322,88 340,80" fill="none" stroke="#16a34a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    <g fill="#16a34a">
        <circle cx="34" cy="62" r="3"/><circle cx="58" cy="54" r="3"/><circle cx="82" cy="68" r="3"/><circle cx="106" cy="50" r="3"/><circle cx="130" cy="78" r="3"/><circle cx="154" cy="66" r="3"/><circle cx="178" cy="70" r="3"/><circle cx="202" cy="48" r="3"/><circle cx="226" cy="62" r="3"/><circle cx="250" cy="56" r="3"/><circle cx="274" cy="82" r="3"/><circle cx="298" cy="70" r="3"/><circle cx="322" cy="88" r="3"/><circle cx="340" cy="80" r="3"/>
    </g>
    <text x="34" y="136" font-size="10" fill="#64748b">00:00</text>
    <text x="126" y="136" font-size="10" fill="#64748b">08:00</text>
    <text x="218" y="136" font-size="10" fill="#64748b">16:00</text>
    <text x="310" y="136" font-size="10" fill="#64748b">20:00</text>
</svg>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="med_admin_main_grid">
                        <div class="med_admin_panel med_admin_panel_users">
                            <div class="med_admin_panel_head">
                                <div>
                                    <h2>User Management</h2>
                                    <p style="color:rgba(255,255,255,.85);font-size:.9rem;">Admins, doctors, and clinical staff</p>
                                </div>
                                <div class="med_admin_panel_head_actions">
                                    <button name="action_open_add_doctor_popup" type="object" class="med_admin_small_btn primary">
                                        <i class="fa fa-user-plus" title="Add Doctor" />
                                        Add Doctor
                                    </button>
                                </div>
                            </div>
                            <field name="doctor_ids" nolabel="1" readonly="1" class="med_admin_table med_admin_users_table">
                                <list create="0" edit="0" delete="0">
                                    <field name="mediot_initial_label" string=" " widget="badge" />
                                    <field name="name" />
                                    <field name="mediot_role_label" string="Role" widget="badge"
                                           decoration-primary="mediot_role_label == 'Admin'"
                                           decoration-info="mediot_role_label == 'Doctor'"
                                           decoration-muted="mediot_role_label == 'Technician'" />
                                    <field name="login" />
                                    <field name="email" />
                                    <button name="action_mediot_open_user" type="object" icon="fa-sliders" string="" title="Manage Doctor" class="oe_link med_admin_action_icon" />
                                    <button name="action_mediot_delete_user" type="object" icon="fa-trash" string="" title="Archive Doctor" class="oe_link text-danger med_admin_action_icon" confirm="This doctor/user may be linked to employee records. Archive this user instead?" />
                                </list>
                            </field>
                        </div>
</div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_med_admin_users_list_clean" model="ir.ui.view">
        <field name="name">med.admin.users.list.clean</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Manage Users" create="1" edit="1" delete="1">
                <field name="name" />
                <field name="mediot_role_label" string="Role" widget="badge"
                                           decoration-primary="mediot_role_label == 'Admin'"
                                           decoration-info="mediot_role_label == 'Doctor'"
                                           decoration-muted="mediot_role_label == 'Technician'" />
                <field name="login" />
                <field name="email" />
                <field name="active" optional="show" />
            </list>
        </field>
    </record>
    <record id="view_med_admin_quick_doctor_wizard_form" model="ir.ui.view">
        <field name="name">med.admin.quick.doctor.wizard.form</field>
        <field name="model">med.admin.quick.doctor.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Doctor">
                <sheet>
                    <div class="med_admin_wizard_intro">
                        <h2>Add Doctor</h2>
                        <p style="color:rgba(255,255,255,.85);font-size:.9rem;">Create a doctor account quickly and assign the correct MedIoT role.</p>
                    </div>
                    <group>
                        <field name="name" placeholder="Full name" />
                        <field name="email" placeholder="doctor@email.com" />
                        <field name="password" password="True" placeholder="Temporary password" />
                        <field name="role" />
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_doctor" type="object" string="Create Doctor" class="btn-primary" />
                    <button string="Cancel" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="view_med_user_role_modal_form" model="ir.ui.view">
        <field name="name">med.user.role.modal.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Manage User" class="med_user_modal_form">
                <sheet>
                    <div class="med_user_modal_shell">
                        <div class="med_user_modal_hero">
                            <div class="med_user_modal_identity">
                                <div class="med_user_modal_kicker">MEDIOT USER MANAGEMENT</div>
                                <h2>
                                    <field name="name" nolabel="1" placeholder="Full name" />
                                </h2>
                                <div class="med_user_modal_role">
                                    <field name="mediot_role_badge" nolabel="1" widget="badge"
                                           decoration-primary="mediot_role_badge == 'Admin'"
                                           decoration-info="mediot_role_badge == 'Doctor'"
                                           decoration-muted="mediot_role_badge == 'Technician'" />
                                </div>
                            </div>
                        </div>

                        <div class="med_user_modal_grid">
                            <div class="med_user_modal_card">
                                <div class="med_user_modal_card_title">
                                    <i class="fa fa-id-card-o" />
                                    Profile Details
                                </div>
                                <group>
                                    <field name="name" string="Name" />
                                    <field name="login" string="Login" />
                                    <field name="email" string="Email" />
                                    <field name="active" string="Active" widget="boolean_toggle" />
                                </group>
                            </div>

                            <div class="med_user_modal_card med_user_modal_card_blue">
                                <div class="med_user_modal_card_title">
                                    <i class="fa fa-shield" />
                                    MedIoT Role
                                </div>
                                <div class="med_user_modal_role_big">
                                    <field name="mediot_role_badge" nolabel="1" widget="badge"
                                           decoration-primary="mediot_role_badge == 'Admin'"
                                           decoration-info="mediot_role_badge == 'Doctor'"
                                           decoration-muted="mediot_role_badge == 'Technician'" />
                                </div>
                                <div class="med_user_role_description">
                                    <field name="mediot_role_description" nolabel="1" readonly="1" />
                                </div>
                            </div>
                        </div>
                    </div>
                </sheet>
                <footer>
                    <button string="Save Changes" special="save" class="btn-primary" />
                    <button string="Cancel" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="view_med_user_role_management_list" model="ir.ui.view">
        <field name="name">med.user.role.management.list</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <list string="Users &amp; Roles" create="1" edit="1" delete="0" class="med_user_role_page_list">
                <field name="mediot_initial_badge" string=" " widget="badge" />
                <field name="name" />
                <field name="mediot_role_badge" string="Role" widget="badge"
                       decoration-primary="mediot_role_badge == 'Admin'"
                       decoration-info="mediot_role_badge == 'Doctor'"
                       decoration-muted="mediot_role_badge == 'Technician'" />
                <field name="login" />
                <field name="email" />
                <field name="active" widget="boolean_toggle" />
                <button name="action_mediot_open_user" type="object" icon="fa-sliders" string="" title="Open User" class="oe_link med_admin_action_icon" />
                <button name="action_mediot_archive_user" type="object" icon="fa-trash" string="" title="Archive User" class="oe_link text-danger med_admin_action_icon" confirm="Archive this user? They will disappear from the active users list and will not be able to log in." />
            </list>
        </field>
    </record>
    <record id="action_med_user_role_management" model="ir.actions.act_window">
        <field name="name">Users &amp; Roles</field>
        <field name="res_model">res.users</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_med_user_role_management_list" />
        <field name="domain">[('share', '=', False), ('active', '=', True)]</field>
        <field name="context">{'create': True, 'edit': True, 'delete': False}</field>
        <field name="target">current</field>
    </record>
    <record id="action_med_admin_dashboard" model="ir.actions.act_window">
        <field name="name">Admin Dashboard</field>
        <field name="res_model">med.admin.dashboard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_med_admin_dashboard_form" />
        <field name="res_id" ref="med_admin_dashboard_singleton" />
        <field name="target">current</field>
    </record>
</odoo>
















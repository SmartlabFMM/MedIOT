<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_med_patient_tree" model="ir.ui.view">
        <field name="name">med.patient.tree</field>
        <field name="model">med.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="ref"/>
                <field name="name"/>
                <field name="room"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'stable'"
                       decoration-warning="status == 'warning'"
                       decoration-danger="status == 'critical'"/>
                <field name="latest_temp"/>
                <field name="latest_spo2"/>
                <field name="latest_ecg_bpm"/>
                <field name="assigned_doctor_id"/>
                <field name="pending_alert_count"/>
            </list>
        </field>
    </record>

    <record id="view_med_patient_form" model="ir.ui.view">
        <field name="name">med.patient.form</field>
        <field name="model">med.patient</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="stable,warning,critical"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                        <div>
                            <field name="ref" readonly="1"/>
                        </div>
                    </div>

                    <group>
                        <group>
                            <field name="age"/>
                            <field name="gender"/>
                            <field name="room"/>
                            <field name="assigned_doctor_id"/>
                            <field name="department"/>
                            <field name="active"/>
                        </group>
                        <group string="Latest Reading">
                            <field name="latest_reading_at" readonly="1"/>
                            <field name="latest_temp" readonly="1"/>
                            <field name="latest_spo2" readonly="1"/>
                            <field name="latest_ecg_bpm" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Alerts">
                            <field name="alert_ids" context="{'default_patient_id': id}">
                                <list>
                                    <field name="severity" widget="badge"
                                           decoration-warning="severity == 'warning'"
                                           decoration-danger="severity == 'critical'"/>
                                    <field name="alert_type"/>
                                    <field name="message"/>
                                    <field name="state"/>
                                    <field name="create_date"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_med_patient_search" model="ir.ui.view">
        <field name="name">med.patient.search</field>
        <field name="model">med.patient</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="ref"/>
                <field name="room"/>
                <filter string="Critical" name="critical" domain="[('status','=','critical')]"/>
                <filter string="Warning" name="warning" domain="[('status','=','warning')]"/>
                <filter string="Stable" name="stable" domain="[('status','=','stable')]"/>
                <separator/>
                <filter string="Doctor" name="group_by_doctor" context="{'group_by': 'assigned_doctor_id'}"/>
                <filter string="Status" name="group_by_status" context="{'group_by': 'status'}"/>
            </search>
        </field>
    </record>

    <record id="action_med_patients" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">med.patient</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_med_patient_search"/>
    </record>
</odoo>

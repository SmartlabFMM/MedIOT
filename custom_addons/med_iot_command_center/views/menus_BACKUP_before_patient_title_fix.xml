<?xml version='1.0' encoding='UTF-8'?>
<odoo>
    <record id="action_med_alerts" model="ir.actions.act_window">
        <field name="name">Real-time Alerts</field>
        <field name="res_model">med.alert</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_med_root" name="MedIoT" sequence="10"/>

    <record id="action_med_dashboard" model="ir.actions.client">
        <field name="name">Command Center</field>
        <field name="tag">med_iot_command_center.dashboard</field>
    </record>

    <menuitem id="menu_med_dashboard" name="Dashboard" parent="menu_med_root" action="action_med_dashboard" sequence="10"/>

    <menuitem id="menu_med_alerts" name="Real-time Alerts" parent="menu_med_root" sequence="20" action="action_med_alerts"/>

    <menuitem id="menu_med_patients" name="Patient List" parent="menu_med_root" sequence="30" action="action_med_patient"/>

    <!-- Hide Patient List from top dashboard menu; patients still open from KPI/View all -->
    <record id="menu_med_patients" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <menuitem id="menu_med_history" name="Data History" parent="menu_med_root" sequence="40" action="action_med_readings"/>

    <menuitem id="menu_med_settings" name="Settings" parent="menu_med_root" sequence="60" action="action_med_settings" groups="med_iot_command_center.group_med_admin"/>
<menuitem id="menu_med_devices" name="Device" parent="menu_med_settings" sequence="10" action="action_med_devices"/>

    <!-- Device is embedded inside Settings page, so hide submenu -->
    <record id="menu_med_devices" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    </odoo>

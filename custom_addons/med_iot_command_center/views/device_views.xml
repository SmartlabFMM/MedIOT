<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_med_device_tree" model="ir.ui.view">
        <field name="name">med.device.tree</field>
        <field name="model">med.device</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="device_uid"/>
                <field name="room"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'online'"
                       decoration-danger="status == 'offline'"/>
                <field name="last_seen"/>
                <field name="patient_id"/>
            </list>
        </field>
    </record>

    <record id="view_med_device_form" model="ir.ui.view">
        <field name="name">med.device.form</field>
        <field name="model">med.device</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="device_uid"/>
                        <field name="room"/>
                        <field name="status"/>
                        <field name="last_seen"/>
                        <field name="patient_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_med_devices" model="ir.actions.act_window">
        <field name="name">Devices</field>
        <field name="res_model">med.device</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>

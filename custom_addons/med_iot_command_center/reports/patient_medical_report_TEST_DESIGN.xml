<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_patient_medical" model="ir.actions.report">
        <field name="name">Patient Medical Report</field>
        <field name="model">med.patient</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">med_iot_command_center.report_patient_medical_document</field>
        <field name="report_file">med_iot_command_center.report_patient_medical_document</field>
        <field name="binding_model_id" ref="model_med_patient"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_patient_medical_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="patient">
                <div class="page" style="font-family: Arial, sans-serif; color:#24395B; padding:24px;">
                    <div style="background:#2F456D; color:white; padding:22px 26px; border-radius:16px; margin-bottom:20px;">
                        <table style="width:100%;">
                            <tr>
                                <td>
                                    <div style="font-size:30px; font-weight:800;">MedIoT</div>
                                    <div style="font-size:13px;">Smart care. Real-time monitoring.</div>
                                </td>
                                <td style="text-align:right;">
                                    <div style="font-size:20px; font-weight:800;">Patient Medical Report</div>
                                    <div style="font-size:12px;">Patient ID: <span t-esc="patient.ref or '-'"/></div>
                                </td>
                            </tr>
                        </table>
                    </div>

                    <h2 style="color:#2F456D;">Patient Information</h2>
                    <table style="width:100%; border-collapse:collapse; font-size:13px; margin-bottom:20px;">
                        <tr>
                            <td style="padding:9px; background:#F1F5F9;">Name</td>
                            <td style="padding:9px; font-weight:bold;"><span t-esc="patient.name or '-'"/></td>
                            <td style="padding:9px; background:#F1F5F9;">Age</td>
                            <td style="padding:9px; font-weight:bold;"><span t-esc="patient.age or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:9px; background:#F1F5F9;">Gender</td>
                            <td style="padding:9px; font-weight:bold;"><span t-esc="patient.gender or '-'"/></td>
                            <td style="padding:9px; background:#F1F5F9;">Room</td>
                            <td style="padding:9px; font-weight:bold;"><span t-esc="patient.room or '-'"/></td>
                        </tr>
                        <tr>
                            <td style="padding:9px; background:#F1F5F9;">Status</td>
                            <td style="padding:9px; font-weight:bold;"><span t-esc="patient.status or '-'"/></td>
                            <td style="padding:9px; background:#F1F5F9;">Generated</td>
                            <td style="padding:9px; font-weight:bold;"><span t-esc="time.strftime('%Y-%m-%d')"/></td>
                        </tr>
                    </table>

                    <h2 style="color:#2F456D;">Latest Vital Signs</h2>
                    <table style="width:100%; border-collapse:collapse; text-align:center; font-size:13px; margin-bottom:20px;">
                        <tr style="background:#2F456D; color:white;">
                            <th style="padding:10px;">SpO2</th>
                            <th style="padding:10px;">Heart Rate</th>
                            <th style="padding:10px;">Temperature</th>
                            <th style="padding:10px;">Last Reading</th>
                        </tr>
                        <tr>
                            <td style="padding:12px;"><span t-esc="patient.latest_spo2 or '-'"/>%</td>
                            <td style="padding:12px;"><span t-esc="patient.latest_ecg_bpm or '-'"/> BPM</td>
                            <td style="padding:12px;"><span t-esc="patient.latest_temp or '-'"/> °C</td>
                            <td style="padding:12px;"><span t-esc="patient.latest_reading_at or '-'"/></td>
                        </tr>
                    </table>

                    <div style="background:#EEF2FF; padding:14px; border-radius:10px; font-size:12px; color:#475569;">
                        This report was generated from MedIoT Command Center using the latest monitored patient data.
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>

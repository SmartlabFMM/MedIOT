<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Patient Medical Report -->
    <report
        id="patient_medical_report"
        model="med.patient"
        string="Patient Medical Report"
        name="med_iot_command_center.patient_medical_report"
        file="med_iot_command_center.patient_medical_report"
        report_type="qweb-pdf"
        paperformat="paperformat_euro"
        print_report_name="'Patient Report - ' + object.ref"/>

    <!-- Report Template -->
    <template id="patient_medical_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!-- Header Section -->
                        <div style="background: linear-gradient(135deg, #5c6bc0 0%, #7986cb 100%); padding: 20px; border-radius: 8px; margin-bottom: 20px; color: white;">
                            <h2 style="margin: 0 0 10px 0; font-size: 24px; font-weight: bold;">Rapport Médical de Suivi</h2>
                            <p style="margin: 0; font-size: 14px; opacity: 0.95;">Medical Follow-up Report</p>
                        </div>

                        <!-- Patient Information Card -->
                        <div style="background: white; border: 1px solid #dde0f5; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
                            <table style="width: 100%; font-size: 11px;">
                                <tr>
                                    <td style="width: 50%; padding: 5px; vertical-align: top;">
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">Patient:</strong>
                                            <span t-esc="doc.name"/>
                                        </div>
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">N° Dossier:</strong>
                                            <span t-esc="doc.ref"/>
                                        </div>
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">Age:</strong>
                                            <span t-esc="doc.age or '—'"/> ans
                                        </div>
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">Sexe:</strong>
                                            <span t-esc="doc.gender and dict([('male', 'Homme'), ('female', 'Femme'), ('other', 'Autre')]).get(doc.gender, '—') or '—'"/>
                                        </div>
                                    </td>
                                    <td style="width: 50%; padding: 5px; vertical-align: top;">
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">Médecin Assigné:</strong>
                                            <span t-esc="doc.assigned_doctor_id.name or '—'"/>
                                        </div>
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">Département:</strong>
                                            <span t-esc="doc.department or '—'"/>
                                        </div>
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">Chambre:</strong>
                                            <span t-esc="doc.room or '—'"/>
                                        </div>
                                        <div style="margin-bottom: 10px;">
                                            <strong style="color: #5c6bc0;">Date du Rapport:</strong>
                                            <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %b %Y')"/>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Latest Vitals Summary -->
                        <div style="background: white; border: 1px solid #dde0f5; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
                            <h3 style="margin: 0 0 12px 0; font-size: 14px; font-weight: bold; color: #0f172a;">Signes Vitaux Récents</h3>
                            <table style="width: 100%; font-size: 11px;">
                                <tr>
                                    <td style="width: 33%; text-align: center; padding: 10px; border-right: 1px solid #f1f5f9;">
                                        <div style="font-size: 24px; font-weight: bold; color: #6C8EFF;">
                                            <t t-esc="doc.latest_spo2 or '—'"/><t t-if="doc.latest_spo2"><span style="font-size: 14px;">%</span></t>
                                        </div>
                                        <div style="color: #64748b; margin-top: 5px;">SPO2</div>
                                    </td>
                                    <td style="width: 33%; text-align: center; padding: 10px; border-right: 1px solid #f1f5f9;">
                                        <div style="font-size: 24px; font-weight: bold; color: #FF2D78;">
                                            <t t-esc="doc.latest_ecg_bpm or '—'"/><t t-if="doc.latest_ecg_bpm"><span style="font-size: 14px;"> bpm</span></t>
                                        </div>
                                        <div style="color: #64748b; margin-top: 5px;">Fréquence Cardiaque</div>
                                    </td>
                                    <td style="width: 33%; text-align: center; padding: 10px;">
                                        <div style="font-size: 24px; font-weight: bold; color: #a78bfa;">
                                            <t t-esc="doc.latest_temp or '—'"/><t t-if="doc.latest_temp"><span style="font-size: 14px;">°C</span></t>
                                        </div>
                                        <div style="color: #64748b; margin-top: 5px;">Température</div>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Status Information -->
                        <div style="background: white; border: 1px solid #dde0f5; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
                            <h3 style="margin: 0 0 12px 0; font-size: 14px; font-weight: bold; color: #0f172a;">État du Patient</h3>
                            <table style="width: 100%; font-size: 11px;">
                                <tr>
                                    <td style="padding: 8px; width: 50%;">
                                        <strong style="color: #5c6bc0;">Statut Actuel:</strong>
                                    </td>
                                    <td style="padding: 8px;">
                                        <t t-set="status_color" t-value="{'critical': '#ef4444', 'warning': '#f59e0b', 'stable': '#10b981'}.get(doc.status, '#94a3b8')"/>
                                        <span t-att-style="'background: ' + status_color + '; color: white; padding: 4px 12px; border-radius: 20px; font-weight: 600; font-size: 11px;'">
                                            <t t-esc="doc.status and doc.status.capitalize() or '—'"/>
                                        </span>
                                    </td>
                                </tr>
                                <t t-if="doc.smoker or doc.prior_cardiac_event or doc.elderly">
                                    <tr>
                                        <td style="padding: 8px; vertical-align: top;">
                                            <strong style="color: #5c6bc0;">Facteurs de Risque:</strong>
                                        </td>
                                        <td style="padding: 8px;">
                                            <t t-if="doc.smoker"><div style="font-size: 11px; color: #64748b;">⚠ Fumeur</div></t>
                                            <t t-if="doc.prior_cardiac_event"><div style="font-size: 11px; color: #ef4444;">⚠ Antécédents Cardiovasculaires</div></t>
                                            <t t-if="doc.elderly"><div style="font-size: 11px; color: #f59e0b;">⚠ Âge Avancé (60+)</div></t>
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>

                        <!-- Recent Alerts Section -->
                        <div style="background: white; border: 1px solid #dde0f5; border-radius: 8px; padding: 15px; margin-bottom: 20px;">
                            <h3 style="margin: 0 0 12px 0; font-size: 14px; font-weight: bold; color: #0f172a;">Alertes Récentes</h3>
                            <t t-set="recent_alerts" t-value="doc.alert_ids[:10]"/>
                            <t t-if="recent_alerts">
                                <table style="width: 100%; font-size: 10px; border-collapse: collapse;">
                                    <thead>
                                        <tr style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                                            <th style="padding: 8px; text-align: left; color: #5c6bc0; font-weight: bold;">Date &amp; Heure</th>
                                            <th style="padding: 8px; text-align: left; color: #5c6bc0; font-weight: bold;">Alerte</th>
                                            <th style="padding: 8px; text-align: left; color: #5c6bc0; font-weight: bold;">Sévérité</th>
                                            <th style="padding: 8px; text-align: left; color: #5c6bc0; font-weight: bold;">État</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="recent_alerts" t-as="alert">
                                            <tr style="border-bottom: 1px solid #f1f5f9;">
                                                <td style="padding: 8px;">
                                                    <t t-esc="context_timestamp(alert.create_date).strftime('%d/%m/%Y %H:%M')"/>
                                                </td>
                                                <td style="padding: 8px;">
                                                    <t t-esc="alert.name or '—'"/>
                                                </td>
                                                <td style="padding: 8px;">
                                                    <t t-set="sev_color" t-value="{'critical': '#ef4444', 'warning': '#f59e0b', 'info': '#3b82f6'}.get(alert.severity, '#64748b')"/>
                                                    <span t-att-style="'background: ' + sev_color + '20; color: ' + sev_color + '; padding: 2px 6px; border-radius: 4px; font-weight: 500;'">
                                                        <t t-esc="alert.severity and alert.severity.capitalize() or '—'"/>
                                                    </span>
                                                </td>
                                                <td style="padding: 8px;">
                                                    <t t-esc="alert.state and alert.state.capitalize() or '—'"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </t>
                            <t t-else="">
                                <p style="color: #94a3b8; font-size: 11px; margin: 0;">Aucune alerte récente</p>
                            </t>
                        </div>

                        <!-- Footer -->
                        <div style="margin-top: 30px; padding-top: 15px; border-top: 1px solid #f1f5f9; font-size: 10px; color: #94a3b8; text-align: center;">
                            <p style="margin: 0;">
                                MedIoT Command Center - Rapport Auto-généré
                            </p>
                            <p style="margin: 5px 0 0 0;">
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d %B %Y à %H:%M')"/>
                            </p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
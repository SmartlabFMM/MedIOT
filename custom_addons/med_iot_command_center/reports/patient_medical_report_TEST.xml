<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_patient_medical" model="ir.actions.report">
        <field name="name">Patient Medical Report</field>
        <field name="model">med.patient</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">med_iot_command_center.report_patient_medical_document</field>
        <field name="report_file">med_iot_command_center.report_patient_medical_document</field>
        <field name="binding_model_id" ref="model_med_patient"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_patient_medical_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="patient">
                <div class="page" style="font-family: Arial, sans-serif; padding: 24px;">
                    <h1 style="color:#24395B; margin-bottom: 4px;">Patient Medical Report</h1>
                    <p style="color:#6b7280; margin-top:0;">MedIoT Command Center</p>

                    <hr style="margin: 18px 0;"/>

                    <h2 style="color:#24395B;">Patient Information</h2>
                    <table style="width:100%; border-collapse: collapse; margin-bottom: 18px;">
                        <tr>
                            <td style="padding:8px; font-weight:bold;">Name</td>
                            <td style="padding:8px;"><span t-field="patient.name"/></td>
                        </tr>
                        <tr>
                            <td style="padding:8px; font-weight:bold;">Patient ID</td>
                            <td style="padding:8px;"><span t-field="patient.ref"/></td>
                        </tr>
                        <tr>
                            <td style="padding:8px; font-weight:bold;">Age</td>
                            <td style="padding:8px;"><span t-field="patient.age"/></td>
                        </tr>
                        <tr>
                            <td style="padding:8px; font-weight:bold;">Gender</td>
                            <td style="padding:8px;"><span t-field="patient.gender"/></td>
                        </tr>
                        <tr>
                            <td style="padding:8px; font-weight:bold;">Room</td>
                            <td style="padding:8px;"><span t-field="patient.room"/></td>
                        </tr>
                        <tr>
                            <td style="padding:8px; font-weight:bold;">Status</td>
                            <td style="padding:8px;"><span t-field="patient.status"/></td>
                        </tr>
                    </table>

                    <h2 style="color:#24395B;">Latest Vitals</h2>
                    <table style="width:100%; border-collapse: collapse;">
                        <tr style="background:#f3f4f6;">
                            <th style="padding:10px; text-align:left;">SpO2</th>
                            <th style="padding:10px; text-align:left;">ECG BPM</th>
                            <th style="padding:10px; text-align:left;">Temperature</th>
                            <th style="padding:10px; text-align:left;">Last Reading</th>
                        </tr>
                        <tr>
                            <td style="padding:10px;"><span t-field="patient.latest_spo2"/>%</td>
                            <td style="padding:10px;"><span t-field="patient.latest_ecg_bpm"/> BPM</td>
                            <td style="padding:10px;"><span t-field="patient.latest_temp"/> °C</td>
                            <td style="padding:10px;"><span t-field="patient.latest_reading_at"/></td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>

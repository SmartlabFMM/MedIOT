<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="med_iot_command_center.Dashboard">
        <div class="med_dashboard">

            <!-- HERO -->
            <div class="med_banner">
                <div class="med_banner_left">
                    <div class="med_banner_greeting">Hi!</div>
                    <div class="med_banner_sub">Welcome to MedIoT Command Center</div>
                    <div class="med_banner_date">
                        <i class="fa fa-calendar"/>
                        <t t-esc="state.todayDate"/>
                    </div>
                </div>

                <div class="med_banner_right">
                    <div class="med_banner_refresh">
                        <i class="fa fa-clock-o"/> Auto-refreshes every 15s · Last updated:
                        <t t-esc="state.lastRefresh or '—'"/>
                    </div>

                    <div class="med_banner_actions">
                        <button type="button" class="med_btn_alert" t-on-click="() => this.openAlerts()">
                            <i class="fa fa-bell"/> Alerts
                            <t t-if="state.kpis.pending_alerts > 0">
                                <span class="med_alert_badge" t-esc="state.kpis.pending_alerts"/>
                            </t>
                        </button>

                        <button type="button" class="med_btn_add" t-on-click="() => this.openPatients()">
                            <i class="fa fa-plus"/> Add Patient
                        </button>
                    </div>
                </div>
            </div>

            <t t-if="state.loading">
                <div class="med_loading">
                    <div class="med_spinner"/>
                    <p>Loading...</p>
                </div>
            </t>

            <t t-else="">
                <!-- KPI CARDS -->
                <div class="med_kpi_row">

                    <div class="med_kpi_card blue" t-on-click="() => this.openPatients()">
                        <div class="med_kpi_icon blue_bg">
                            <i class="fa fa-users"/>
                        </div>
                        <div class="med_kpi_body">
                            <div class="med_kpi_label">Total Patients</div>
                            <div class="med_kpi_value" t-esc="state.kpis.total"/>
                            <div class="med_kpi_trend">Active patients monitored</div>
                        </div>
                    </div>

                    <div class="med_kpi_card red" t-on-click="() => this.openCriticalPatients()">
                        <div class="med_kpi_icon med_kpi_icon_img">
                            <img src="/med_iot_command_center/static/description/critical-v2.png"
                                 alt="Critical"
                                 class="med_kpi_img"/>
                        </div>
                        <div class="med_kpi_body">
                            <div class="med_kpi_label">Critical</div>
                            <div class="med_kpi_value" t-esc="state.kpis.critical"/>
                            <div class="med_kpi_trend">Needs immediate attention</div>
                        </div>
                    </div>

                    <div class="med_kpi_card orange" t-on-click="() => this.openWarningPatients()">
                        <div class="med_kpi_icon med_kpi_icon_img">
                            <img src="/med_iot_command_center/static/description/warning-v2.png"
                                 alt="Warning"
                                 class="med_kpi_img"/>
                        </div>
                        <div class="med_kpi_body">
                            <div class="med_kpi_label">Warning</div>
                            <div class="med_kpi_value" t-esc="state.kpis.warning"/>
                            <div class="med_kpi_trend">Monitoring clinically</div>
                        </div>
                    </div>

                </div>

                <!-- SEARCH / FILTER BAR — above table card -->
                <div class="lpm_toolbar">
                    <div class="lpm_toolbar_right">
                        <div class="lpm_search_box">
                            <input type="text"
                                   class="lpm_search_input"
                                   placeholder="Search patients..."
                                   t-att-value="state.searchQuery"
                                   t-on-input="onSearchInput"/>
                            <i class="fa fa-search lpm_search_icon"/>
                        </div>

                        <select class="lpm_status_select" t-on-change="onStatusChange">
                            <option value="all" t-att-selected="state.statusFilter === 'all'">All Status</option>
                            <option value="stable" t-att-selected="state.statusFilter === 'stable'">Stable</option>
                            <option value="warning" t-att-selected="state.statusFilter === 'warning'">Warning</option>
                            <option value="critical" t-att-selected="state.statusFilter === 'critical'">Critical</option>
                        </select>
                    </div>
                </div>

                <!-- LIVE PATIENT MONITORS -->
                <div class="lpm_wrap">
                    <div class="lpm_header">
                        <span class="lpm_title">Live Patient Monitors</span>
                        <a href="#" class="lpm_viewall" t-on-click.prevent="() => this.openPatients()">View all →</a>
                    </div>

                    <t t-if="this.filteredLive.length == 0">
                        <div class="lpm_empty">No patients currently monitored</div>
                    </t>

                    <t t-else="">
                        <table class="lpm_table">
                            <thead>
                                <tr>
                                    <th>Patient Name</th>
                                    <th>Patient ID</th>
                                    <th>Age</th>
                                    <th>Condition</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="this.filteredLive" t-as="p" t-key="p.id">
                                    <tr class="lpm_row" t-on-click="() => this.openPatient(p.id)">
                                        <td>
                                            <div class="lpm_namecell">
                                                <div t-att-class="'lpm_avatar lpm_av_' + (p.status || 'stable')" style="overflow:hidden;padding:0;">
                                                    <t t-if="p.image_128">
                                                        <img t-att-src="'data:image/png;base64,' + p.image_128"
                                                             style="width:32px;height:32px;border-radius:50%;object-fit:cover;display:block;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <t t-esc="p.name ? p.name[0].toUpperCase() : '?'"/>
                                                    </t>
                                                </div>
                                                <span class="lpm_name" t-esc="p.name"/>
                                            </div>
                                        </td>

                                        <td>
                                            <span class="lpm_id" t-esc="p.ref or '—'"/>
                                        </td>

                                        <td>
                                            <span class="lpm_age">
                                                <t t-if="p.age">
                                                    <t t-esc="p.age"/> yrs
                                                </t>
                                                <t t-else="">—</t>
                                            </span>
                                        </td>

                                        <td>
                                            <span class="lpm_condition">
                                                <t t-if="p.latest_spo2 and p.latest_ecg_bpm">
                                                    SpO2: <t t-esc="p.latest_spo2"/>% · <t t-esc="p.latest_ecg_bpm"/> BPM
                                                </t>
                                                <t t-elif="p.latest_spo2">
                                                    SpO2: <t t-esc="p.latest_spo2"/>%
                                                </t>
                                                <t t-elif="p.latest_ecg_bpm">
                                                    <t t-esc="p.latest_ecg_bpm"/> BPM
                                                </t>
                                                <t t-else="">Monitoring</t>
                                            </span>
                                        </td>

                                        <td>
                                            <span t-att-class="'lpm_badge lpm_badge_' + (p.status || 'stable')">
                                                <t t-esc="p.status ? p.status.charAt(0).toUpperCase() + p.status.slice(1) : '—'"/>
                                            </span>
                                        </td>

                                        <td t-on-click.stop="">
                                            <div class="lpm_actions">
                                                <button type="button" class="lpm_btn lpm_btn_view" title="View" t-on-click="() => this.openPatient(p.id)">
                                                    <i class="fa fa-eye"/>
                                                </button>
                                                <button type="button" class="lpm_btn lpm_btn_edit" title="Edit" t-on-click="() => this.openPatient(p.id)">
                                                    <i class="fa fa-pencil"/>
                                                </button>
                                                <button type="button" class="lpm_btn lpm_btn_alert" title="Alerts" t-on-click="() => this.openPatientAlerts(p.id)">
                                                    <i class="fa fa-bell"/>
                                                </button>
                                                <button type="button" class="lpm_btn lpm_btn_download" title="Download Report" t-on-click="() => this.downloadPatientReport(p.id)">
                                                    <i class="fa fa-download"/>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        </div>
    </t>

</templates>